{
  "name": "CommitForge — CLI para Commits Retroativos no Git",
  "short_name": "CommitForge",
  "description": "CLI open-source para criar commits retroativos no Git com datas do passado. Suporta GitHub, GitLab e Bitbucket.",
  "start_url": "/",
  "display": "standalone",
  "background_color": "#000000",
  "theme_color": "#000000",
  "orientation": "any",
